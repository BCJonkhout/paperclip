{
  "realm": "paperclip",
  "enabled": true,
  "clients": [
    {
      "clientId": "paperclip-client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "paperclip-secret",
      "redirectUris": [
        "http://localhost:3100/*",
        "http://localhost:13100/*"
      ],
      "webOrigins": [
        "*"
      ]
    }
  ],
  "users": [
    {
      "username": "user",
      "enabled": true,
      "email": "user@example.com",
      "firstName": "Paperclip",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ]
    }
  ]
}
